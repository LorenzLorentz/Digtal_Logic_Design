# Everything in vivado/ except checked-in IP/repo and build.tcl is
# auto-generated by build.tcl or by Vivado runtime. Wipe at will.

# Stateless batch build output
build/

# Auto-generated GUI project (recreated by build.tcl on demand)
chat.xpr
chat.srcs/
chat.cache/
chat.runs/
chat.sim/
chat.hw/
chat.gen/
chat.ip_user_files/

# Vivado logs / journals / temp checkpoints
*.jou
*.log
*.str
*.dcp
.Xil/
.Xilinx/
